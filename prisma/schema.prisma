// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  clerkId   String     @unique // ID from Clerk Auth
  email     String     @unique
  name      String?
  isPaid      Boolean    @default(false)
  orders      Order[]
  favorites   Favorite[]
  submissions      ChallengeSubmission[]
  
  // Referral & Anti-Fraud
  referralCode     String?    @unique // Short 5-char code (e.g. ABC12)
  referredById     String?
  referredBy       User?           @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]          @relation("UserReferrals")
  registrationIp   String?
  deviceFingerprint String?
  rewards          ReferralReward[] @relation("ReferrerRewards")
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String   @unique // Generated by us, sent to Midtrans
  midtransId    String?  @unique // Populated heavily on success
  status        String   @default("PENDING") // PENDING, SETTLED, EXPIRED
  amount        Int      @default(8000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Prompt {
  id          String     @id @default(uuid())
  category    String     // One of the 10 categories
  title       String
  content     String
  isPremium   Boolean    @default(true) // Set to false for Sneak Peeks
  favorites   Favorite[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  promptId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // Ensure a user can only favorite a prompt once
  @@unique([userId, promptId]) 
}

// Dynamic configuration store (key-value)
model Config {
  key   String @id
  value String
}

model ChallengeSubmission {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String   // tiktok, reels
  videoUrl  String
  username  String   // social media handle
  views     Int      @default(0) // New: For 'Reach' points calculation
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ReferralVisit {
  id                String   @id @default(uuid())
  referrerId        String   // ID of the user who shared the link
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  createdAt         DateTime @default(now())

  @@index([referrerId])
  @@index([ipAddress])
}

model ReferralReward {
  id             String   @id @default(uuid())
  referrerId     String   // Recipient
  referrer       User     @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String   // Who bought
  orderId        String   @unique
  amount         Float    // 15% of total
  status         String   @default("SETTLED") // PENDING, SETTLED, WITHDRAWN
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([referrerId])
}
